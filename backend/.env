# ============================================
# VARIÁVEIS DE AMBIENTE - LOJA VIRTUAL
# ============================================

# Porta do servidor
PORT=5000

# Chave secreta JWT (mude isso em produção!)
SECRET_KEY=sua-chave-secreta-super-segura-2026

# Ambiente (development, production)
NODE_ENV=development

# ============================================
# BANCO DE DADOS
# ============================================

# SQLite (padrão, em memória)
DB_TYPE=sqlite
DB_PATH=:memory:

# OU PostgreSQL
# DB_TYPE=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=virtual_store
# DB_USER=postgres
# DB_PASSWORD=senha

# ============================================
# STRIPE (Pagamentos)
# ============================================

# STRIPE_PUBLIC_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...

# ============================================
# EMAIL (Nodemailer)
# ============================================

# EMAIL_SERVICE=gmail
# EMAIL_USER=seu-email@gmail.com
# EMAIL_PASSWORD=sua-senha-app

# ============================================
# FRONTEND
# ============================================

# URL do frontend (para CORS)
FRONTEND_URL=http://localhost:3000

# URL da API
API_URL=http://localhost:5000/api

# ============================================
# LOGGING
# ============================================

# Log Level: error, warn, info, debug
LOG_LEVEL=debug

# ============================================
# INSTRÇÕES DE USO
# ============================================

# 1. Copie este arquivo como .env
# 2. Preencha as variáveis necessárias
# 3. NUNCA commite o arquivo .env (adicione ao .gitignore)
# 4. Em produção, use variáveis de ambiente reais
